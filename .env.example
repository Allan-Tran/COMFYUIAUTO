RUNPOD_API_KEY=rp_XXXXXXXXXXXXXXXXXXXXXXXX
RUNPOD_ENDPOINT_ID=your_endpoint_id
TELEGRAM_BOT_TOKEN=1234567890:your_bot_token_from_botfather
TELEGRAM_CHAT_ID=-1001234567890

# Optional: default TelegramSender node id in your workflow JSON.
# TELEGRAM_NODE_ID=99

# Optional: override node IDs/input keys if your workflow differs from defaults.
# POSITIVE_NODE_ID=3
# POSITIVE_INPUT_KEY=text
# NEGATIVE_NODE_ID=4
# NEGATIVE_INPUT_KEY=text
# LENGTH_NODE_ID=5
# LENGTH_INPUT_KEY=length
# I2V_NODE_ID=
# I2V_INPUT_KEY=image_base64

# Optional: required for gated Hugging Face models.
# HUGGING_FACE_HUB_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# Optional: tracked model list JSON file merged into input.models.
# MODELS_JSON_PATH=input_models.json

# Optional: local testing mode to avoid Telegram upload side effects.
# TELEGRAM_UPLOAD_ENABLED=false
# DELETE_UPLOADED_MP4=false

# Optional: ComfyUI launch performance flags (enabled by default in worker).
# COMFYUI_HIGH_VRAM=true
# COMFYUI_DISABLE_SMART_MEMORY=true
# COMFYUI_FP8_E4M3FN_UNET=true
