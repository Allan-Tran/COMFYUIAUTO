      },
      "99": {
        "class_type": "TelegramSender",
        "inputs": {
          "trigger": [
            "8",
            0
          ],
          "bot_token": "1234567890:REPLACE_WITH_YOUR_BOT_TOKEN",
          "chat_id": "REPLACE_WITH_YOUR_CHAT_ID",
