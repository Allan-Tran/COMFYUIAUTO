      },
      "6": {
        "class_type": "KSampler",
        "inputs": {
          "seed": 42,
          "steps": 30,
          "cfg": 3,
          "sampler_name": "euler",
          "scheduler": "normal",
          "denoise": 1,
          "model": [
            "1",
            0
          ],
          "positive": [
            "3",
            0
          ],
          "negative": [
            "4",
            0
          ],
          "latent_image": [
            "5",
            0
          ]
        }
      },
      "7": {
        "class_type": "VAEDecode",
        "inputs": {
          "samples": [
            "6",
            0
          ],
          "vae": [
            "2",
            0
          ]
        }
      },
      "8": {
        "class_type": "VHS_VideoCombine",
        "inputs": {
          "images": [
            "7",
            0
          ],
          "frame_rate": 24,
          "format": "video/h264-mp4",
          "pix_fmt": "yuv420p",
          "crf": 20,
          "save_output": true,
          "filename_prefix": "runpod_ltx_video"
