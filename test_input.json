            1
          ]
        }
      },
      "4": {
        "class_type": "CLIPTextEncode",
        "inputs": {
          "text": "low quality, blurry, artifacts",
          "clip": [
            "1",
            1
          ]
        }
      },
      "5": {
        "class_type": "EmptyLTXVLatentVideo",
        "inputs": {
          "width": 768,
          "height": 432,
          "length": 97,
